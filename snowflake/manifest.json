{
  "name": "snowflake-client",
  "buildsystem": "simple",
  "build-options": {
    "append-path": "/usr/lib/sdk/golang/bin",
    "env": {
      "GOBIN": "/app/bin",
      "GOROOT": "/usr/lib/sdk/golang"
    }
  },
  "build-commands": [
    "cd client && go build -mod=vendor -o snowflake-client",
    "install -Dm755 client/snowflake-client -t ${FLATPAK_DEST}/snowflake/pts"
  ],
  "sources": [
    {
      "type": "archive",
      "url": "https://gitlab.torproject.org/tpo/anti-censorship/pluggable-transports/snowflake/-/archive/v2.13.1/snowflake-v2.13.1.tar.gz",
      "sha256": "3102c0782422205f6cea7609ab67cb5fd080e048880712ebe0c85540138cc09f"
    },
    "go.mod.yml"
  ]
}
